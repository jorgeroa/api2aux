{
  "name": "@api2aux/api-invoke",
  "version": "0.4.0",
  "description": "Parse any API spec and execute operations — OpenAPI, raw URLs, or manual endpoints",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "export $(grep -v '^#' .env | xargs) 2>/dev/null; vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch"
  },
  "keywords": [
    "openapi",
    "swagger",
    "api-client",
    "runtime"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jorgeroa/api2aux.git",
    "directory": "packages/api-invoke"
  },
  "homepage": "https://github.com/jorgeroa/api2aux/tree/main/packages/api-invoke#readme",
  "bugs": {
    "url": "https://github.com/jorgeroa/api2aux/issues"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0"
  },
  "devDependencies": {
    "openapi-types": "^12.1.3",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.17",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}
